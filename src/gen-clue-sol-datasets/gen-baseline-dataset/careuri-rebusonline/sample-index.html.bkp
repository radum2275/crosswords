<!doctype html>
<!--[if lt IE 7]> <html class="no-js ie6 oldie" lang="en"> <![endif]-->
<!--[if IE 7]>    <html class="no-js ie7 oldie" lang="en"> <![endif]-->
<!--[if IE 8]>    <html class="no-js ie8 oldie" lang="en"> <![endif]-->
<!--[if gt IE 8]><!--> <html class="no-js" lang="en"> <!--<![endif]-->
<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
	<title>Qurossword - A javascript crossword puzzle plugin</title>
	<meta name="viewport" content="width=device-width,initial-scale=1">
	<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.6.2/jquery.min.js"></script>
	<script src="js/jquery.crossword.js"></script>
	<script src="js/sample-index.js"></script>

	<style type="text/css" media="screen">
	/*
		Default puzzle styling
	*/
	body {
		font: 62.5%/1.3em Helvetica, sans-serif;
		width: 90.3%;
		margin: 10px auto;
	}
		table.clues {
			background-color: #fff;
		}
		table.grid {
			border-collapse: collapse; 
			border-spacing: 0; 
			max-width: 100%;
		}
		table.grid{
			border: 2px solid;
		}
		table.grid tr{
			width: 100%;
		}
		table.grid td {
			width: 5em;
			height: 5em;
			border: 1px solid #000000;
			padding: 0;
			margin: 0;
			background-color: #333;
			position: relative;
		}
				
		td input {
			width: 100%;
			height: 100%;
			padding: 0em;
			border: none;
			text-align: center;
			font-size: 2.7em;
			color: #000;
			background-color: #ffffff;
			text-transform: capitalize;
		}
		
		td input:focus {
			background-color: #ffff99;
		}
		
		td span {
			color: #444;
			font-size: 0.8em;
			position: absolute;
			top: -1px;
			left: 1px;
		}
		
		input.done {
			font-weight: bold;
			color: green;
		}
		
		.active,
		.clues-active {
			background-color: #ffff99;
		}
		.clue-done {
			color: #999;
			text-decoration: line-through;
		}
		
		#puzzle-wrapper {
			float: left;
			width: 45%;
			margin-right: 1%;
		}
		#puzzle-clues {
			float: left;
			width: 52%;
		}
		
		#puzzle-clues li{
			font-size: 1.8em;
			margin: .1em;
			line-height: 1.1em;
		}

		#other-info{
			font-size: 1.8em;
			margin: .1em;
			line-height: 1.2em;
		}		
		
	</style>

</head>

<body>
	
<div id="puzzle-wrapper"><!-- crossword puzzle appended here --></div>

</body>
</html>	